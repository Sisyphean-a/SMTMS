<UserControl
    d:DesignHeight="600"
    d:DesignWidth="1000"
    mc:Ignorable="d"
    x:Class="SMTMS.Avalonia.Views.ModListView"
    x:DataType="vm:MainViewModel"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SMTMS.Avalonia.ViewModels"
    xmlns:cv="using:SMTMS.Avalonia.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <cv:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <cv:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <cv:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock.Spinning">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="2*, 4, 1*">
        <!--  Mod List  -->
        <Panel Grid.Column="0">
        <DataGrid
            AutoGenerateColumns="False"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,1,0"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding ModListViewModel.Mods}"
            RowBackground="Transparent"
            SelectedItem="{Binding ModListViewModel.SelectedMod}"
            x:CompileBindings="False"
            x:Name="ModsGrid">
            <DataGrid.Styles>
                <Style Selector="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Style>
                <Style Selector="DataGridRow" x:DataType="vm:ModViewModel">
                    <Setter Property="Tag" Value="{Binding RowStatus}" />
                    <Setter Property="FontStyle" Value="{Binding IsDirty, Converter={StaticResource BoolToFontStyleConverter}}" />
                </Style>
                <!-- 1 = Changed (Local modification) -->
                <Style Selector="DataGridRow[Tag=1]">
                    <Setter Property="Foreground" Value="{StaticResource GeekBlueBrush}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Style>
                <!-- 2 = New (Untracked) -->
                <Style Selector="DataGridRow[Tag=2]">
                    <Setter Property="Foreground" Value="#00C853" /> <!-- Green for new items -->
                    <Setter Property="FontStyle" Value="Italic" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTemplateColumn
                    Header="Open"
                    Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ModViewModel">
                            <Button
                                Command="{Binding #Root.DataContext.ModListViewModel.OpenModFolderCommand}"
                                CommandParameter="{Binding}"
                                Content="Open"
                                HorizontalAlignment="Center"
                                Padding="8,2"
                                ToolTip.Tip="打开模组文件夹"
                                AutomationProperties.Name="打开模组目录" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Binding="{Binding Name}"
                    Header="名称"
                    IsVisible="{Binding #Root.DataContext.ModListViewModel.ShowNameColumn}"
                    Width="200" />
                <DataGridTemplateColumn
                    Header="版本"
                    IsVisible="{Binding #Root.DataContext.ModListViewModel.ShowVersionColumn}"
                    SortMemberPath="Version"
                    Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ModViewModel">
                            <Panel>
                                <Button
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding OpenNexusPageCommand}"
                                    Content="{Binding Version}"
                                    CornerRadius="0"
                                    Cursor="Hand"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="12"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    IsVisible="{Binding HasNexusUrl}"
                                    Margin="0"
                                    Padding="12,0,0,0"
                                    ToolTip.Tip="点击访问 Nexus 页面"
                                    AutomationProperties.Name="访问 Nexus 页面"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Center" />
                                <TextBlock
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="12"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding HasNexusUrl, Converter={StaticResource BoolNegationConverter}}"
                                    Margin="0"
                                    Padding="12,0,0,0"
                                    Text="{Binding Version}"
                                    VerticalAlignment="Center" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Binding="{Binding UniqueID}"
                    FontFamily="{StaticResource MonoFont}"
                    FontSize="11"
                    Header="唯一 ID"
                    IsVisible="{Binding #Root.DataContext.ModListViewModel.ShowIdColumn}"
                    Width="250" />

                <DataGridTextColumn
                    Binding="{Binding Description}"
                    Header="描述"
                    IsVisible="{Binding #Root.DataContext.ModListViewModel.ShowDescriptionColumn}"
                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

            <!-- Empty State -->
            <StackPanel
                HorizontalAlignment="Center"
                IsVisible="{Binding ModListViewModel.HasMods, Converter={StaticResource BoolNegationConverter}}"
                Spacing="20"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="48"
                    HorizontalAlignment="Center"
                    Text="📭" />
                <StackPanel Spacing="10">
                    <TextBlock
                        FontWeight="Bold"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        HorizontalAlignment="Center"
                        Text="暂无模组数据" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        HorizontalAlignment="Center"
                        Text="请检查目录设置或点击下方按钮重新扫描" />
                </StackPanel>
                <Button
                    Classes="Solid"
                    Command="{Binding ModListViewModel.LoadModsCommand}"
                    Content="扫描模组"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Panel>

        <GridSplitter
            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Grid.Column="1"
            ResizeDirection="Columns"
            Width="1" />

        <!--  Detail Pane  -->
        <Panel Grid.Column="2">
            <Border
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding ModListViewModel.SelectedMod, Converter={x:Static ObjectConverters.IsNull}}"
                Padding="20"
                VerticalAlignment="Stretch">
                <StackPanel
                    HorizontalAlignment="Center"
                    Spacing="15"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="48"
                        HorizontalAlignment="Center"
                        Opacity="0.5"
                        Text="📦" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        HorizontalAlignment="Center"
                        Text="未选择模组" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        HorizontalAlignment="Center"
                        Text="👈 请在左侧列表中选择一个模组以开始编辑" />
                </StackPanel>
            </Border>

            <Border
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0"
                IsVisible="{Binding #Root.DataContext.ModListViewModel.SelectedMod, Converter={x:Static ObjectConverters.IsNotNull}}"
                DataContext="{Binding ModListViewModel.SelectedMod}"
                x:CompileBindings="False"
                Padding="20">

                <Grid RowDefinitions="Auto, *">
                <TextBlock
                    FontFamily="{StaticResource MonoFont}"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="{StaticResource GeekBlueBrush}"
                    Grid.Row="0"
                    Margin="0,0,0,15"
                    Text="模组详情编辑" />

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="20">
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="10"
                                FontWeight="Bold"
                                Opacity="0.6"
                                Text="名称" />
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox
                                    Grid.Column="0"
                                    Text="{Binding Name}" />
                                <Button
                                    Grid.Column="1"
                                    Classes="Tertiary"
                                    Command="{Binding TranslateNameCommand}"
                                    FontSize="16"
                                    Height="32"
                                    IsEnabled="{Binding IsTranslatingName, Converter={StaticResource BoolNegationConverter}}"
                                    Margin="8,0,0,0"
                                    Padding="4"
                                    ToolTip.Tip="翻译名称"
                                    AutomationProperties.Name="翻译名称"
                                    Width="40">
                                    <Panel>
                                        <TextBlock Text="🌐" IsVisible="{Binding IsTranslatingName, Converter={StaticResource BoolNegationConverter}}" />
                                        <TextBlock Text="🔄"
                                                   Classes="Spinning"
                                                   IsVisible="{Binding IsTranslatingName}"
                                                   RenderTransformOrigin="50%,50%">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Panel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="10"
                                FontWeight="Bold"
                                Opacity="0.6"
                                Text="唯一 ID" />
                            <TextBox
                                FontFamily="{StaticResource MonoFont}"
                                IsReadOnly="True"
                                Opacity="0.7"
                                Text="{Binding UniqueID}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="10"
                                FontWeight="Bold"
                                Opacity="0.6"
                                Text="N网 ID" />
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox
                                    FontFamily="{StaticResource MonoFont}"
                                    Grid.Column="0"
                                    IsEnabled="{Binding IsNexusIdEditable}"
                                    Text="{Binding NexusId}"
                                    Watermark="输入 N网 模组 ID（纯数字）" />
                                <Button
                                    Classes="Tertiary"
                                    Command="{Binding OpenNexusPageCommand}"
                                    Content="链接"
                                    Grid.Column="1"
                                    IsVisible="{Binding HasNexusUrl}"
                                    Margin="8,0,0,0"
                                    ToolTip.Tip="在浏览器中打开 Nexus 页面"
                                    AutomationProperties.Name="打开 Nexus 页面" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="10"
                                FontWeight="Bold"
                                Opacity="0.6"
                                Text="描述" />
                            <Grid ColumnDefinitions="*, Auto" RowDefinitions="*">
                                <TextBox
                                    AcceptsReturn="True"
                                    Grid.Column="0"
                                    Height="120"
                                    Text="{Binding Description}"
                                    TextWrapping="Wrap"
                                    VerticalContentAlignment="Top" />
                                <Button
                                    Grid.Column="1"
                                    Classes="Tertiary"
                                    Command="{Binding TranslateDescriptionCommand}"
                                    FontSize="16"
                                    Height="32"
                                    IsEnabled="{Binding IsTranslatingDescription, Converter={StaticResource BoolNegationConverter}}"
                                    Margin="8,0,0,0"
                                    Padding="4"
                                    ToolTip.Tip="翻译描述"
                                    AutomationProperties.Name="翻译描述"
                                    VerticalAlignment="Top"
                                    Width="40">
                                    <Panel>
                                        <TextBlock Text="🌐" IsVisible="{Binding IsTranslatingDescription, Converter={StaticResource BoolNegationConverter}}" />
                                        <TextBlock Text="🔄"
                                                   Classes="Spinning"
                                                   IsVisible="{Binding IsTranslatingDescription}"
                                                   RenderTransformOrigin="50%,50%">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Panel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0"
                            Orientation="Horizontal"
                            Spacing="15">
                            <Button
                                Classes="Tertiary"
                                Command="{Binding ShowHistoryCommand}"
                                Content="查看历史"
                                ToolTip.Tip="查看该模组的历史变更记录"
                                AutomationProperties.Name="查看历史" />
                            <Button
                                Classes="Warning"
                                Command="{Binding DiscardChangesCommand}"
                                Content="放弃变更"
                                IsVisible="{Binding IsDirty}" 
                                Theme="{DynamicResource TertiaryButton}"
                                ToolTip.Tip="撤销所有未保存的更改，恢复到原始状态"
                                AutomationProperties.Name="放弃更改" />
                            <Button
                                Classes="Solid"
                                Command="{Binding #Root.DataContext.ModListViewModel.SaveModCommand}"
                                Content="保存更改"
                                ToolTip.Tip="保存对当前模组的修改 (Ctrl+S)"
                                AutomationProperties.Name="保存更改" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            </Border>
        </Panel>
    </Grid>
</UserControl>
